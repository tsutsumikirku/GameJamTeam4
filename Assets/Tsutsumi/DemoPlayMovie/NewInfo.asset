  InfoDataArray:
  - Text: "\u30AF\u30EC\u30FC\u30F3\u30B2\u30FC\u30E0\u3067\u4E8C\u4EBA\u5BFE\u6226\u3002
      \u76F8\u624B\u3088\u308A\u591A\u304F\u306E\u30B9\u30B3\u30A2\u3092\u96C6\u3081\u308B\u3068\u52DD\u3061\u3060\uFF01"
    Image: {fileID: 0}
  - Text: "\u64CD\u4F5C\u306F\u5358\u7D14\u3002 \u30DC\u30BF\u30F3\u3092\u62BC\u3057\u3066\u3044\u308B\u9593\u30AF\u30EC\u30FC\u30F3\u306F\u52D5\u304D\u3001
      \u96E2\u3059\u3068\u3064\u304B\u3080\u3002\u30AF\u30EC\u30FC\u30F3\u304C\u3082\u3068\u306B\u623B\u308B\u307E\u3067\u52D5\u304B\u305B\u306A\u3044\u3002"
    Image: {fileID: 0}
  - Text: "\u30AD\u30E3\u30E9\u3054\u3068\u306B\u7570\u306A\u308B\u6027\u80FD\u306E\u30AF\u30EC\u30FC\u30F3\u3092\u6301\u3064\u3002
      \u30AF\u30EC\u30FC\u30F3\u9078\u3073\u304B\u3089\u6226\u3044\u306F\u59CB\u307E\u3063\u3066\u3044\u308B\uFF01"
    Image: {fileID: 0}
